FROM public.ecr.aws/lambda/python:3.11

# Runtime deps only — no PyTorch
RUN pip install --no-cache-dir \
    onnxruntime==1.27.0 \
    tokenizers==0.22.2 \
    numpy==2.5.0

# ONNX model + tokenizer (pre-exported by scripts/export_to_onnx.py)
COPY lambda/onnx/model.onnx      /var/task/
COPY lambda/onnx/tokenizer.json  /var/task/

# Pre-computed question index (generated by scripts/precompute_embeddings.py)
COPY lambda/shared/data/          /var/task/data/

# Shared search utility + handler
COPY lambda/shared/search.py      /var/task/
COPY lambda/onnx/handler.py       /var/task/

CMD ["handler.handler"]
